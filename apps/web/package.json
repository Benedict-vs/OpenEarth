{
  "name": "openearth-web",
  "private": true,
  "version": "2.0.0-alpha.0",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "gen": "openapi-typescript openapi.json -o src/api/types.gen.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.0",
    "maplibre-gl": "^5.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "terra-draw": "^1.15.0",
    "terra-draw-maplibre-gl-adapter": "^1.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^6.1.0",
    "openapi-typescript": "^7.9.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0",
    "vite": "^7.2.0",
    "vitest": "^3.2.0"
  }
}
