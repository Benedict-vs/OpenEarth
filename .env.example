# OpenEarth settings (pydantic-settings, prefix OPENEARTH_). Copy to .env.

# Google Cloud project with Earth Engine enabled (required for EE routes).
OPENEARTH_EE_PROJECT=

# Where cache/, catalog.d/, and later openearth.db live (relative to CWD).
OPENEARTH_DATA_DIR=data

# Assumed getMapId tile-URL lifetime; clients re-mint at 75 % of this.
OPENEARTH_TILE_TTL_SECONDS=14400

# Global cap on concurrent Earth Engine requests.
OPENEARTH_EE_MAX_CONCURRENCY=8

# Optional override for the CH4 absorption LUT (.npz). Unset = the packaged v3.
# OPENEARTH_LUT_PATH=

# NASA Earthdata credentials for the EMIT V002 plume fallback (earthaccess reads
# its OWN env — these are NOT OPENEARTH_-prefixed settings). Set EARTHDATA_TOKEN
# (an Earthdata Login bearer token) OR EARTHDATA_USERNAME + EARTHDATA_PASSWORD,
# or place them in ~/.netrc. Unset = the EMIT V002 path returns 502; the frozen
# GEE V001 mirror (windows ≤ 2024-10-26) needs no Earthdata credentials.
# EARTHDATA_TOKEN=
