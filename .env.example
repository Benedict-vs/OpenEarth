# OpenEarth settings (pydantic-settings, prefix OPENEARTH_). Copy to .env.

# Google Cloud project with Earth Engine enabled (required for EE routes).
OPENEARTH_EE_PROJECT=

# Where cache/, catalog.d/, and later openearth.db live (relative to CWD).
OPENEARTH_DATA_DIR=data

# Assumed getMapId tile-URL lifetime; clients re-mint at 75 % of this.
OPENEARTH_TILE_TTL_SECONDS=14400

# Global cap on concurrent Earth Engine requests.
OPENEARTH_EE_MAX_CONCURRENCY=8

# Optional override for the CH4 absorption LUT (.npz). Unset = the packaged v2.
# OPENEARTH_LUT_PATH=
